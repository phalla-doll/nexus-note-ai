# Copy to .env.local and fill in. Never commit real secrets.

# NVIDIA Build API key — used server-side from app/api/chat/route.ts via
# lib/ai/providers/nvidia.ts. Get one at https://build.nvidia.com.
NVIDIA_API_KEY=

# Cloudflare D1 (production database, single-environment dev). Used by
# lib/db/d1-driver.ts to talk to the D1 HTTP API.
#
# Create an API token with permission "Account → D1 → Edit" scoped to the
# account below. Token UI: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=e63e1c513f59ba1e5c5a83d2931cf61b
CLOUDFLARE_D1_DATABASE_ID=f5ffd20e-3946-41f1-8702-ca3fc1381a6a
CLOUDFLARE_API_TOKEN=

# Cloudflare R2 (file storage). S3-compatible credentials — separate from
# the API token above. Create in dashboard:
#   R2 → Manage R2 API Tokens → Create API Token
#   Permissions: Object Read & Write on `nexus-note-ai-files`
R2_BUCKET_NAME=nexus-note-ai-files
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
